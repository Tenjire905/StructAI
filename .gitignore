# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files (official Expo template)
.env*.local

# Secrets / API keys (BYOK via expo-secure-store – never commit)
.env
.env.*
!.env.example
secrets/
*.secret

# logs
*.log

# local dev screenshots
.screenshots/

# CocoaPods (when ios/ is present)
ios/Pods/

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
